{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production node --import tsx server.ts",
    "preview": "npm run start",
    "clean": "rm -rf dist .next",
    "lint": "tsc --noEmit",
    "db:start": "sh ./scripts/setup-local-postgres.sh",
    "db:stop": "sudo service postgresql stop",
    "db:setup": "npm run db:start && npm run db:generate && npm run db:push && npm run db:seed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "next": "^15.4.6",
    "nodemailer": "^8.0.4",
    "prisma": "^6.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
